# SMTP credentials for sending daily job digest emails.
# Copy this file to `.env` (without the .example suffix) and fill in real
# values. The real .env file is gitignored — never commit credentials.
#
# Quick setup:
#   1. Open https://myaccount.google.com/apppasswords (signed into the dedicated
#      Gmail account that's authorized in the Cowork Gmail MCP).
#   2. Generate a new App Password (any name, e.g. "Job Pipeline SMTP").
#   3. Copy the 16-character password (Google shows it once).
#   4. Paste it as SMTP_PASSWORD below, with no spaces.
#   5. Save as `.env` (drop the .example suffix). Done.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465

# The dedicated Gmail address the pipeline sends FROM (the one connected to the Cowork Gmail MCP).
SMTP_USER=REPLACE-WITH-DEDICATED-EMAIL@gmail.com

# 16-character app password (NOT your Google account password).
SMTP_PASSWORD=REPLACE-WITH-16-CHAR-APP-PASSWORD

# Optional display name shown to recipients.
SMTP_FROM_NAME=Job Pipeline
