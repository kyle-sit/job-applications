# --- Per-profile content (machine-local; bootstrap from profiles/_template/) ---
# Ignore everything under profiles/ except the _template dir.
profiles/*
!profiles/_template/

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/

# --- macOS ---
.DS_Store

# --- Editors ---
.vscode/
.idea/
*.swp

# --- Secrets / env ---
.env
.env.local
*.pem
